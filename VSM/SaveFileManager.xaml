<Window x:Class="SoulMaskServerManager.SaveFileManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulMaskServerManager"
        mc:Ignorable="d"
        Title="更换服务器存档" Height="650" Width="1000"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--<TextBlock Grid.Row="0" Text="更换服务器存档" FontSize="18" FontWeight="Bold" Margin="0 0 0 10"/>-->

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Silver" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="选择存档文件或文件夹" FontSize="14" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <TabControl Margin="0 0 0 10" Height="400">
                        <TabItem Header="拖拽放入存档">
                            <Border BorderBrush="LightGray" BorderThickness="1"
                                    Margin="5" Background="#F9F9F9"
                                    AllowDrop="True"
                                    DragEnter="DragDrop_DragEnter"
                                    DragLeave="DragDrop_DragLeave"
                                    Drop="DragDrop_Drop">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                    <Image Source="Resources\icon_Download.png" Height="64" Width="64" Margin="0 0 0 10"/>
                                    <TextBlock x:Name="DragStatusText" Text="拖拽.save文件或存档文件夹到此处" 
                                               FontSize="12" Foreground="Gray"/>
                                    <TextBlock Text="或" Margin="0 10 0 10" Foreground="Gray"/>
                                    <Button Content="浏览文件" Click="BrowseFile_Click" Padding="8 3" Margin="0 5 0 0"/>
                                    <Button Content="浏览文件夹" Click="BrowseFolder_Click" Padding="8 3" Margin="0 5 0 0"/>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <TabItem Header="检测电脑中存档">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                    <TextBlock Text="版本筛选:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                                    <CheckBox x:Name="CheckV3" Content="v3 (1.0版本)" IsChecked="True" 
                                              Checked="VersionFilter_Checked" Unchecked="VersionFilter_Checked"/>
                                    <CheckBox x:Name="CheckV4" Content="v4 (1.1版本)" IsChecked="True"
                                              Checked="VersionFilter_Checked" Unchecked="VersionFilter_Checked"/>
                                    <Button Content="刷新" Click="RefreshSaves_Click" Margin="10 0 0 0" Padding="5 2"/>
                                </StackPanel>

                                <TreeView x:Name="SavesTreeView" Margin="0 5 0 0" Height="330"
                                          SelectedItemChanged="SavesTreeView_SelectedItemChanged">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image x:Name="ItemImage" Width="16" Height="16" Margin="0 0 5 0"/>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text=" (" Foreground="Gray" Margin="5 0 0 0"/>
                                                <TextBlock Text="{Binding ExtraInfo}" Foreground="Gray"/>
                                                <TextBlock Text=")" Foreground="Gray"/>
                                            </StackPanel>
                                            <HierarchicalDataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="User">
                                                    <Setter TargetName="ItemImage" Property="Source" Value="Resources\icon_Download.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Version">
                                                    <Setter TargetName="ItemImage" Property="Source" Value="Resources\icon_Download.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="SaveFolder">
                                                    <Setter TargetName="ItemImage" Property="Source" Value="Resources\icon_Download.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="SaveFile">
                                                    <Setter TargetName="ItemImage" Property="Source" Value="Resources\icon_Download.png"/>
                                                </DataTrigger>
                                            </HierarchicalDataTemplate.Triggers>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <TextBlock Text="选中的存档:" FontWeight="SemiBold" Margin="0 5 0 0"/>
                    <TextBlock x:Name="SelectedSaveInfo" Text="未选择任何存档" Foreground="Gray" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="Silver"/>

            <Border Grid.Column="2" BorderBrush="Silver" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="选择目标服务器" FontSize="14" FontWeight="SemiBold" Margin="0 0 0 10"/>

                    <Button Content="刷新服务器列表" Click="RefreshServers_Click" Margin="0 0 0 10" Padding="5 2" HorizontalAlignment="Left"/>

                    <ListBox x:Name="ServersListBox" Height="400" Margin="0 0 0 10"
                             SelectionChanged="ServersListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Margin="0 2 0 2" Padding="5">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding vsmServerName}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Runtime.State}" Margin="10 0 0 0" />
                                        </StackPanel>
                                        <TextBlock Text="显示名称: {Binding LaunchSettings.DisplayName}" FontSize="12" Foreground="Gray" Margin="0 2 0 0"/>
                                        <TextBlock Text="存档路径: {Binding SavePath}" FontSize="11" Foreground="Gray" Margin="0 2 0 0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="选中的服务器:" FontWeight="SemiBold" Margin="0 5 0 0"/>
                    <TextBlock x:Name="SelectedServerInfo" Text="未选择任何服务器" Foreground="Gray" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button x:Name="UseSaveButton" Content="应用存档到服务器" Click="UseSelectedSave_Click" 
                    Padding="10 5" Margin="0 0 10 0" IsEnabled="False"/>
            <Button Content="取消" Click="Cancel_Click" Padding="10 5"/>
        </StackPanel>
    </Grid>
</Window>
    