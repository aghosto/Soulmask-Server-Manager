<Window x:Class="SoulmaskServerManager.RconConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulmaskServerManager"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="RCON终端" MinHeight="670" Height="670" MinWidth="830" Width="830" ResizeMode="CanResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5 5 0 0" Grid.Column="0">
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <GroupBox Header="RCON设置" HorizontalAlignment="Left">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="IP地址：" Width="80" VerticalAlignment="Center"/>
                            <TextBox x:Name="Ipaddress" DockPanel.Dock="Right" Width="110" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="端口：" Width="80" VerticalAlignment="Center"/>
                            <ui:NumberBox x:Name="Port" HorizontalAlignment="Right" Width="110" SpinButtonPlacementMode="Hidden" Minimum="1" Maximum="65535"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="密码：" Width="80" VerticalAlignment="Center"/>
                            <TextBox x:Name="Password" DockPanel.Dock="Right" Width="110" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DockPanel Margin="0,5,0,5" HorizontalAlignment="Center">
                            <Button x:Name="ConnectButton" Content="连接" HorizontalAlignment="Left" Click="ConnectButton_Click"/>
                            <Button x:Name="DisconnectButton" Content="断开连接" HorizontalAlignment="Left" Click="DisconnectButton_Click" IsEnabled="False" Margin="10,0,0,0"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <GroupBox Header="指令">
                    <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                        <ListBox x:Name="CommandList" 
                                Width="190" 
                                Height="360">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" 
                                                ToolTip="{Binding ToolTip}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0 5 0 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <RichTextBox x:Name="RconConsoleOutput" 
                             Grid.Row="0"
                             Foreground="Lime" 
                             Background="Black" 
                             IsReadOnly="True"
                             Height="580"
                             Width="600"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>

                    <StackPanel Grid.Row="1" Margin="5">
                        <DockPanel>
                            <TextBlock Text="参数：" Width="80" VerticalAlignment="Center"/>
                            <TextBox x:Name="ParamaterTextbox" Width="440"/>
                            <Button x:Name="SendCommandButton" Content="发送" Margin="5,0,0,0" Click="SendCommandButton_Click" IsEnabled="False"/>
                        </DockPanel>
                    </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
