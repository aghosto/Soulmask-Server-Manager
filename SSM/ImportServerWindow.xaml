<Window x:Class="SoulmaskServerManager.ImportServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulmaskServerManager" 
        xmlns:ui="http://schemas.modernwpf.com/2019" xmlns:local1="clr-namespace:SoulmaskServerManager.Controls"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="服务器导入窗口" Height="250" Width="350" WindowStartupLocation="CenterOwner">
    <Grid>
        <Border
            x:Name="DropArea"
            AllowDrop="True"
            Drop="DropArea_Drop"
            DragEnter="DropArea_DragEnter"
            DragLeave="DropArea_DragLeave">

            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ImportProgressText"
                    Text="拖入服务器文件夹到这里"
                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    FontSize="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                <TextBlock
                Text="拖入后最好点击一下窗口"
                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                FontSize="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
