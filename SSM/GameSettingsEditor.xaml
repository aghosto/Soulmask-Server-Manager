<Window x:Class="SoulmaskServerManager.GameSettingsEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulmaskServerManager"
        xmlns:models="clr-namespace:SoulmaskServerManager.Models"
        xmlns:controls="clr-namespace:SoulmaskServerManager.Controls"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="服务器系数编辑" Height="750" Width="1200" MinHeight="600" MinWidth="900"
        Icon="Resources\icon_EditDocument.png">

    <Window.Resources>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <controls:NumberBoxFormatter x:Key="NumberBoxFormatter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <Button Click="ImportConfig_Click" Margin="2,0" ToolTip="从文件导入系数配置">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="OpenFile" Margin="0,0,3,0"/>
                    <TextBlock Text="导入"/>
                </StackPanel>
            </Button>
            <Button Click="SaveConfig_Click" Margin="2,0" ToolTip="保存系数配置到文件">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Save" Margin="0,0,3,0"/>
                    <TextBlock Text="保存"/>
                </StackPanel>
            </Button>
            <Button Click="ExportConfig_Click" Margin="2,0" ToolTip="导出当前系数配置">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Download" Margin="0,0,3,0"/>
                    <TextBlock Text="导出"/>
                </StackPanel>
            </Button>
            <Button Click="ApplyConfig_Click" Margin="2,0" ToolTip="将系数实时应用到运行中的服务器">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Send" Margin="0,0,3,0"/>
                    <TextBlock Text="应用"/>
                </StackPanel>
            </Button>
            <Button x:Name="ResetDefaultButton" Click="ResetToDefault_Click" Margin="2,0" ToolTip="将所有系数重置为默认值">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Refresh" Margin="0,0,3,0"/>
                    <TextBlock Text="重置为默认"/>
                </StackPanel>
            </Button>
            <Separator Margin="5,0" Width="2" Height="25"/>
            <Button Click="ExitConfig_Click" Margin="2,0" ToolTip="关闭编辑器">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Cancel" Margin="0,0,3,0"/>
                    <TextBlock Text="退出"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="UnappliedChangesText" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Red" Visibility="Collapsed"/>
        </StackPanel>
        <TabControl Grid.Row="1" x:Name="CategoryTabControl">
            <TabItem Header="通用">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <StackPanel Margin="0,3">
                            <TextBlock Text="驯服蛮人速度倍率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The greater the value, the faster Recognition increases."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.AddRenKeDuRatio, Mode=TwoWay}" Minimum="0.1" Maximum="1000" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.AddRenKeDuRatio, Mode=TwoWay}" Minimum="0.1" Maximum="1000" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="白天时间占比" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The greater the value, the shorter the night duration."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GameWorldDayTimePortion, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GameWorldDayTimePortion, Mode=TwoWay}" Minimum="0" Maximum="1" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="时间流速倍率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The greater the value, the faster the time passes."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GameWorldTimePower, Mode=TwoWay}" Minimum="1" Maximum="288" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GameWorldTimePower, Mode=TwoWay}" Minimum="1" Maximum="288" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="角色重塑时间倍率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The greater the value, the faster the remodeling"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.ChongsuRatio, Mode=TwoWay}" Minimum="0.1" Maximum="100" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.ChongsuRatio, Mode=TwoWay}" Minimum="0.1" Maximum="100" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="部落招募族人上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Tribe Recruitment limit"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GongHuiMaxZhaoMuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GongHuiMaxZhaoMuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="强兼容模块1级增加可招募族人数量" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Lv. 1 Mask Node Connection Enhancement increases max tribesman recruits."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenMaxZhaoMuCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenMaxZhaoMuCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="强兼容模块2级增加可招募族人数量" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Lv. 2 Mask Node Connection Enhancement increases max tribesman recruits."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenMaxZhaoMuCount_Two, Mode=TwoWay}" Minimum="1" Maximum="200" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenMaxZhaoMuCount_Two, Mode=TwoWay}" Minimum="1" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="强兼容模块3级增加可招募族人数量" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Lv. 3 Mask Node Connection Enhancement increases max tribesman recruits."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenMaxZhaoMuCount_Three, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenMaxZhaoMuCount_Three, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="心情增长倍率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The higher the value, the higher the Mood increase rate when tribesmen&#x27;s needs are met."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.XinQingZengZhang, Mode=TwoWay}" Minimum="0" Maximum="10" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.XinQingZengZhang, Mode=TwoWay}" Minimum="0" Maximum="10" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="心情减少倍率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The higher the value, the higher the Mood reduction rate when tribesmen&#x27;s needs are unmet."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.XinQingJianShao, Mode=TwoWay}" Minimum="0" Maximum="10" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.XinQingJianShao, Mode=TwoWay}" Minimum="0" Maximum="10" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="部落动物数量上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Tribe Animals Quantity Limit"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GongHuiMaxDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GongHuiMaxDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="个人动物数量上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Personal Animal Quantity Limit"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenMaxDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenMaxDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="宝箱掉落包等级" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Chest Drop Level"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.BaoXiangDiaoLuoDengJi, Mode=TwoWay}" Minimum="0" Maximum="4" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.BaoXiangDiaoLuoDengJi, Mode=TwoWay}" Minimum="0" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="玩家离线多少天后族人休眠不工作" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="How many days of being offline will result in your tribesmen no longer working?"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.XiuMianOfflineDays, Mode=TwoWay}" Minimum="0" Maximum="360" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.XiuMianOfflineDays, Mode=TwoWay}" Minimum="0" Maximum="360" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="跳舞冷却时间(h)" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Dancing Interval (in hours)"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.TiaoWuLengQueTime, Mode=TwoWay}" Minimum="0" Maximum="24" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.TiaoWuLengQueTime, Mode=TwoWay}" Minimum="0" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="信息录入数量上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max number of tribesmen info allowed for Info Entry"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.XinXiLuRu, Mode=TwoWay}" Minimum="1" Maximum="10" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.XinXiLuRu, Mode=TwoWay}" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="最大负重倍率（服务器重启生效）" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max Load Multiplier"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.MaxFuZhongRatio, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.MaxFuZhongRatio, Mode=TwoWay}" Minimum="1" Maximum="100" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="角色包裹容量（服务器重启或角色重生生效）" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Default Character Backpack Capacity Settings"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.RoleBagCapacity, Mode=TwoWay}" Minimum="30" Maximum="256" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.RoleBagCapacity, Mode=TwoWay}" Minimum="30" Maximum="256" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="个人标记个数上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The maximum number of custom map markers that can be placed by a single player."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenBiaoJiMaxCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenBiaoJiMaxCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="共享标记个数上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The maximum number of custom map markers that can be shared with a tribe."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GongHuiBiaoJiMaxCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GongHuiBiaoJiMaxCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="部落人数" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Tribe Players"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GongHuiMaxMember, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GongHuiMaxMember, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="召唤距离系数" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Mount summon distance. The higher the value, the farther you can summon a mount."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.ZhaoHuanDisRatio, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.ZhaoHuanDisRatio, Mode=TwoWay}" Minimum="1" Maximum="100" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="神秘转化台转化效率" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Greater the value, faster the conversion with the Mysterious Converter."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.ConverPropsSpeedRatio, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.ConverPropsSpeedRatio, Mode=TwoWay}" Minimum="1" Maximum="100" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="神秘转化台建造上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max Mysterious Converters Constructible by Individual or Tribe"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.MaxConvertCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.MaxConvertCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="巨象与船只负重物品重量倍率（值越小能负载的物品越多）" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="The smaller the value, the higher the weight capacity of platform animals."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.KurmaFuZhongRatio, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.KurmaFuZhongRatio, Mode=TwoWay}" Minimum="0" Maximum="1" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="部落特定动物（巨象）数量上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Maximum number of giant elephants that can be owned by a tribe"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GongHuiMaxSpecDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GongHuiMaxSpecDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="个人特定动物（巨象）数量上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Maximum number of giant elephants that can be owned by a player"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.GeRenMaxSpecDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.GeRenMaxSpecDongWuCount, Mode=TwoWay}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="精神恢复速度系数" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Morale Recovery Speed. The higher the value, the faster the morale recovers."/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.MentalRecoveryRate, Mode=TwoWay}" Minimum="0" Maximum="10" SmallChange="0.001" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.MentalRecoveryRate, Mode=TwoWay}" Minimum="0" Maximum="10" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="可跟随的动物的最大数量" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max followable animals"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.AnimalFollowerMaxCount, Mode=TwoWay}" Minimum="0" Maximum="100" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.AnimalFollowerMaxCount, Mode=TwoWay}" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="动力索道建筑建造上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max Number of Power Ropeways Buildable per Player or Tribe"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.MaxConveyorCount, Mode=TwoWay}" Minimum="1" Maximum="10000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.MaxConveyorCount, Mode=TwoWay}" Minimum="1" Maximum="10000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="动力矿场建造上限" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Max Number of Power Mines Buildable per Player or Tribe"/>
                            <DockPanel>
                                <ui:NumberBox Value="{Binding Settings.General.MaxDongLiKuangChangCount, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" SpinButtonPlacementMode="Hidden" Width="175" NumberFormatter="{StaticResource NumberBoxFormatter}" Margin="10,0,5,0" DockPanel.Dock="Right"/>
                                <Slider Value="{Binding Settings.General.MaxDongLiKuangChangCount, Mode=TwoWay}" Minimum="1" Maximum="1000" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                        <Separator/>
                        <StackPanel Margin="0,3">
