<Window x:Class="SoulmaskServerManager.ModManagerWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulmaskServerManager"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="服务器Mod管理" Height="790" Width="1080" ResizeMode="CanResize">

    <Grid>
        <ui:SimpleStackPanel Orientation="Vertical">
            <ui:CommandBar>
                <ui:CommandBar.Content>
                    <DockPanel Margin="0 5 0 0">
                        <TextBlock Text="服务器：" VerticalAlignment="Center" Padding="10,0,0,0"/>
                        <ComboBox Name="SteamServerComboBox" ItemsSource="{Binding Servers}" DisplayMemberPath="ssmServerName" VerticalAlignment="Center" Width="Auto" Margin="5" SelectionChanged="ServerComboBox_SelectionChanged" ToolTip="选择要管理的服务器。"/>
                        <TextBlock VerticalAlignment="Center" DataContext="{Binding SelectedItem, ElementName=SteamServerComboBox}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BepInExInstalled}" Value="True">
                                            <Setter Property="Text" Value="BepInEx：已安装："/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding BepInExInstalled}" Value="False">
                                            <Setter Property="Text" Value="BepInEx：未安装"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text=" 搜索：" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        <TextBox x:Name="ModSearchBox" 
                            Width="250" 
                            VerticalAlignment="Center" 
                            Margin="5,0,20,0"
                            ToolTip="输入Mod名称、ModId搜索"
                            KeyDown="ModSearchBox_KeyDown">
                        <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundAltMediumBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10">
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" 
                                                            Margin="0,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Click="SearchIcon_Click"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                            <ui:SymbolIcon Symbol="Find"/>
                                                        </Button>

                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                    Margin="5,0,5,0" 
                                                                    VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Button Content="刷新MOD列表" Click="BtnLoad_Click" Margin="0 0 10 0"/>
                        <Button Content="保存MOD订阅信息" Click="BtnSave_Click" Margin="0 0 10 0"/>
                        <Button Content="取消订阅所有MOD" Click="UnInstallAllMod_Click"/>

                    </DockPanel>
                </ui:CommandBar.Content>
            </ui:CommandBar>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgMods"
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        Height="680"
                        CanUserResizeColumns="False"
                        CanUserResizeRows="False"
                        AutoGenerateColumns="False" 
                        CanUserAddRows="False" 
                        CanUserDeleteRows="False" 
                        CanUserReorderColumns="False" 
                        SelectionChanged="DgMods_SelectionChanged" 
                        SelectionMode="Single" 
                        RowHeaderWidth="0">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制 MOD 名称" Click="CopyCommon_Click" Tag="Title">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Character"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="复制 MOD ID" Click="CopyCommon_Click" Tag="Id">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Memo"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="复制 作者 名称" Click="CopyCommon_Click" Tag="Author">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="AddFriend"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="只看该作者" Click="ShowOnlyThisAuthor_Click">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Manage"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentMediumBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mod名称" Width="300" Binding="{Binding Title}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="TextBlock.TextTrimming" Value="None"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Mod ID" Width="100" Binding="{Binding Id}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="作者" Width="130" Binding="{Binding Author}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="TextBlock.TextTrimming" Value="None"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridCheckBoxColumn Header="订阅" Width="50" Binding="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="365"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Mod信息" Padding="5" Margin="5" Width="450">
                        <ScrollViewer>
                            <StackPanel x:Name="ModInfoPanel">
                                <Image Name="ModImage" HorizontalAlignment="Center" Stretch="Fill" Width="200" Height="112" Margin="0,0,0,10"/>

                                <DockPanel>
                                    <TextBlock Text="Mod名称：" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock x:Name="ModTitleText" Text="" VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap"/>
                                </DockPanel>

                                <DockPanel>
                                    <StackPanel Width="250">
                                        <DockPanel Margin="0,5,0,0">
                                            <TextBlock Text="ModID：" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock x:Name="ModIdText" Text="" VerticalAlignment="Center" FontSize="13"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,5,0,0">
                                            <TextBlock Text="作者：" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock x:Name="ModAuthorText" Text="" VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap"/>
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <DockPanel Margin="0,5,0,0">
                                            <TextBlock Text="订阅人数：" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock x:Name="ModSubsText" Text="" VerticalAlignment="Center" FontSize="13"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,5,0,0">
                                            <TextBlock Text="作者主页：" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock  VerticalAlignment="Center" FontSize="13">
                                            <Hyperlink x:Name="ModAuthorHyperlink" RequestNavigate="Hyperlink_RequestNavigate_Click">
                                                打开作者主页
                                            </Hyperlink>
                                            </TextBlock>
                                        </DockPanel>
                                    </StackPanel>
                                </DockPanel>

                                <DockPanel Margin="0,15,0,0">
                                    <TextBlock Text="基础描述：" FontWeight="Bold" FontSize="15"/>
                                </DockPanel>
                                <TextBlock x:Name="ModDescText" Text="" TextWrapping="Wrap" Margin="0,5,0,0" FontSize="13" LineHeight="18" LineStackingStrategy="BlockLineHeight"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                    <StackPanel HorizontalAlignment="Center" Grid.Row="1">
                        <Button Content="打开创意工坊页面" Width="200" Click="OpenWorkshopPage_Click" HorizontalAlignment="Center"/>
                        
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="InstallModsText" Text="服务器已订阅Mods：" FontSize="20" Margin="5"/>
                        <DockPanel VerticalAlignment="Center" Height="36">
                            <TextBlock Text="手动添加ModID：" VerticalAlignment="Center" FontSize="18" Margin="5 0 0 0"/>
                            <TextBox x:Name="TxtManualModId" Width="180" VerticalAlignment="Center"/>
                            <Button x:Name="BtnAddManualModId" Content="添加" Margin="5,0,0,0" Click="BtnAddManualModId_Click"/>
                        </DockPanel>
                        <DataGrid x:Name="installedMods"
                                    Height="200"
                                    CanUserResizeColumns="False"
                                    CanUserResizeRows="False"
                                    AutoGenerateColumns="False" 
                                    CanUserAddRows="False" 
                                    CanUserDeleteRows="False" 
                                    CanUserReorderColumns="False" 
                                    SelectionMode="Single" 
                                    RowHeaderWidth="0"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="InstalledMods_PreviewMouseLeftButtonDown"
                                    MouseMove="InstalledMods_MouseMove"
                                    DragOver="InstalledMods_DragOver"
                                    Drop="InstalledMods_Drop">

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="复制 MOD 名称" Click="CopyCommon_Click" Tag="Title">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Character"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="复制 MOD ID" Click="CopyCommon_Click" Tag="Id">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Memo"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="取消订阅 MOD" Click="DeleteCommon_Click" Tag="Id">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Delete" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMarkedForDelete}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundBaseLowBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentMediumBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mod名称" Width="300" Binding="{Binding Title}" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="TextBlock.TextTrimming" Value="None"/>
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Mod ID" Width="150" Binding="{Binding Id}" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                    </StackPanel>
                </Grid>
            </Grid>
        </ui:SimpleStackPanel>
        
        <StatusBar Height="35" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="btnPrev" Content="上一页" Width="75" Click="BtnPrev_Click" IsEnabled="False"/>
                <Button x:Name="btnNext" Content="下一页" Width="75" Click="BtnNext_Click" Margin="5,0,0,0"/>
                <TextBlock x:Name="txtPageInfo" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtStatus" Margin="10,0,0,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>

</Window>
