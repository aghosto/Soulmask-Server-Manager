<Window x:Class="SoulMaskServerManager.ManagerSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoulMaskServerManager"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="管理器设置" Height="600" MaxHeight="1000" Width="800" Icon="Resources\icon_Settings.png" ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" Grid.Column="0">
            <DockPanel>
                <TabControl Padding="10" DockPanel.Dock="Top">
                    <TabItem Header="主要设置" RenderTransformOrigin="1.786,0.684">
                        <StackPanel >
                            <GroupBox Header="主要设置" >
                                <DockPanel>
                                    <StackPanel RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left">
                                        <StackPanel.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform AngleX="0.282"/>
                                                <RotateTransform/>
                                                <TranslateTransform X="-1.009"/>
                                            </TransformGroup>
                                        </StackPanel.RenderTransform>
                                        <CheckBox Content="搜索应用程序更新" IsChecked="{Binding AppSettings.AutoUpdateApp, Mode=TwoWay}" ToolTip="VSM是否在启动时检查自身新版本" FontSize="18"/>
                                        <CheckBox Content="验证更新" IsChecked="{Binding AppSettings.VerifyUpdates, Mode=TwoWay}" ToolTip="SteamCMD更新服务器后是否验证游戏文件完整性，建议启用以修复损坏文件" FontSize="18"/>
                                        <CheckBox Content="自动更新服务器" IsChecked="{Binding AppSettings.AutoUpdate, Mode=TwoWay}" ToolTip="VSM是否自动检查并更新游戏服务器" FontSize="18" Margin="0, 10, 0, 0"/>
                                        <DockPanel Width="140" HorizontalAlignment="Left">
                                            <TextBlock Text="间隔：" VerticalAlignment="Center" FontSize="18"/>
                                            <ui:NumberBox Value="{Binding AppSettings.AutoUpdateInterval}" Maximum="1440" Minimum="1" SpinButtonPlacementMode="Hidden" Margin="10,0,0,0" IsEnabled="{Binding AppSettings.AutoUpdate}" ToolTip="自动检查更新的时间间隔（单位：分钟）"/>
                                        </DockPanel>
                                        <CheckBox Content="显示SteamCMD窗口" IsChecked="{Binding AppSettings.ShowSteamWindow, Mode=TwoWay}" ToolTip="更新服务器时是否显示SteamCMD命令窗口，用于排查更新失败问题（已有多种判断报错原因，目前已弃用）" FontSize="18" Margin="0, 10, 0, 0" IsEnabled="False" ToolTipService.ShowOnDisabled="True"/>
                                        <CheckBox Content="启用黑暗模式" IsChecked="{Binding AppSettings.DarkMode, Mode=TwoWay}" ToolTip="切换应用程序的明暗主题" FontSize="18"/>
                                        <CheckBox Content="自动加载设置文件" IsChecked="{Binding AppSettings.AutoLoadEditor, Mode=TwoWay}" ToolTip="设置编辑器是否自动加载当前选中服务器的配置文件" FontSize="18"/>
                                        <CheckBox Content="启用MOD支持" Name="ModSupportCheckBox" IsEnabled="False" IsChecked="{Binding AppSettings.EnableModSupport}" ToolTip="启用对游戏模组（BepInEx）的支持功能" Click="ModSupportCheckBox_Click" FontSize="18"/>
                                        <CheckBox Content="服务器崩溃重启时保存Log备份" Name="SaveLogWhenCrashCheckBox" IsChecked="{Binding AppSettings.SaveLogWhenCrash}" ToolTip="服务器崩溃或重启时自动备份日志文件到CrashLog目录" FontSize="18"/>
                                        <DockPanel Margin="0,15,0,0">
                                            <StackPanel>
                                                <TextBlock Text="关闭按钮行为：" FontSize="18" Margin="5,0,0,5" FontWeight="Medium"/>
                                                <ComboBox 
                                                        x:Name="CloseExecuteSelectCombo" 
                                                        VerticalAlignment="Top" 
                                                        Width="300" 
                                                        Margin="5,0,5,0" 
                                                        OverridesDefaultStyle="True"
                                                        SelectedIndex="{Binding AppSettings.CloseExecuteSelect, Mode=TwoWay}">
                                                    <ComboBoxItem Content="直接退出程序"/>
                                                    <ComboBoxItem Content="最小化到托盘"/>
                                                </ComboBox>
                                                <TextBlock Text="设置点击窗口关闭按钮后的行为" FontSize="12" Margin="5,5,0,0" Foreground="Gray"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <StackPanel.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform AngleX="0.282"/>
                                                <RotateTransform/>
                                                <TranslateTransform X="-1.009"/>
                                            </TransformGroup>
                                        </StackPanel.RenderTransform>
                                        <CheckBox IsEnabled="False" Content="启用自动重启功能" IsChecked="{Binding AppSettings.EnableAutoRestart, Mode=TwoWay}" FontSize="18" Margin="0 0 0 10" ToolTip="启用每日固定时间自动重启所有运行中的服务器"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:NumberBox Value="{Binding AppSettings.AutoRestartHour}" IsEnabled="{Binding AppSettings.EnableAutoRestart}" PlaceholderText="00" TextAlignment="Center"/>
                                            <TextBlock Text="时" FontSize="18" VerticalAlignment="Center"/>
                                            <ui:NumberBox Value="{Binding AppSettings.AutoRestartMin}"  IsEnabled="{Binding AppSettings.EnableAutoRestart}" PlaceholderText="00" TextAlignment="Center"/>
                                            <TextBlock Text="分" FontSize="18" VerticalAlignment="Center"/>
                                            <ui:NumberBox Value="{Binding AppSettings.AutoRestartSec}"  IsEnabled="{Binding AppSettings.EnableAutoRestart}" PlaceholderText="00" TextAlignment="Center"/>
                                            <TextBlock Text="秒" FontSize="18" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Webhook设置" IsEnabled="False">
                        <GroupBox Header="Webhook设置">
                            <StackPanel>
                                <CheckBox Name="WebhookCheck" Content="启动" IsChecked="{Binding WebhookSettings.Enabled}" ToolTip="启用通过Discord Webhook发送通知消息"/>
                                <DockPanel Margin="0,5,0,0">
                                    <TextBlock Width="75" Text="URL:" VerticalAlignment="Center"/>
                                    <TextBox IsEnabled="{Binding WebhookSettings.Enabled}" Text="{Binding WebhookSettings.URL, Mode=TwoWay}" ToolTip="Discord频道的Webhook URL（在频道设置中创建）"/>
                                </DockPanel>
                                <TextBlock Text="信息" Margin="0,10,0,0" FontSize="20"/>
                                <DockPanel Margin="0,5,0,0">
                                    <TextBlock Width="100" Text="已找到更新：" VerticalAlignment="Center"/>
                                    <TextBox IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookSettings.UpdateFound, Mode=TwoWay}" ToolTip="检测到游戏服务器更新时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                </DockPanel>
                                <DockPanel Margin="0,5,0,0">
                                    <TextBlock Width="100" Text="更新等待时间：" VerticalAlignment="Center"/>
                                    <TextBox IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookSettings.UpdateWait, Mode=TwoWay}" ToolTip="服务器将在5分钟后关闭更新时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                </DockPanel>
                                <Button Content="重置" Width="100" HorizontalAlignment="Left" Margin="0,10,0,0" Click="ResetButton_Click" ToolTip="将所有Webhook消息恢复为默认文本"/>
                                <Separator Margin="0,10,0,10"/>
                                <GroupBox Header="自定义服务器消息" DataContext="{Binding ElementName=ServerTabControl, Path=SelectedItem}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="选择要自定义的服务器：" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                            <ComboBox Name="ServerCombo" ItemsSource="{Binding Servers}" DisplayMemberPath="vsmServerName" Width="250"/>
                                            <Button Content="重置" Name="ResetServerButton" Width="100" HorizontalAlignment="Left" Margin="10,0,0,0" Click="ResetServerButton_Click" ToolTip="将当前服务器的消息恢复为默认文本"/>
                                        </DockPanel>
                                        <StackPanel Margin="0,10,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=ServerCombo, Path=SelectedItem}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <CheckBox Content="启用" DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsChecked="{Binding WebhookMessages.Enabled}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" ToolTip="启用当前服务器的Webhook通知" ToolTipService.ShowOnDisabled="True"/>
                                            <DockPanel Margin="0,5,0,0">
                                                <TextBlock Text="服务器正在启动：" Width="150" VerticalAlignment="Center"/>
                                                <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookMessages.StartServer}" ToolTip="服务器启动时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,5,0,0">
                                                <TextBlock Text="服务器正在停止：" Width="150" VerticalAlignment="Center"/>
                                                <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookMessages.StopServer}" ToolTip="服务器停止时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,5,0,0">
                                                <TextBlock Text="服务器就绪：" Width="150" VerticalAlignment="Center"/>
                                                <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookMessages.ServerReady}" ToolTip="服务器启动完成时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,5,0,0">
                                                <TextBlock Text="3次启动尝试：" Width="150" VerticalAlignment="Center"/>
                                                <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookMessages.AttemptStart3, Mode=OneWay}" ToolTip="服务器连续3次启动失败时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,5,0,0">
                                                <TextBlock Text="服务器崩溃：" Width="150" VerticalAlignment="Center"/>
                                                <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" Text="{Binding WebhookMessages.ServerCrash}" ToolTip="服务器崩溃时发送的通知（留空禁用）" ToolTipService.ShowOnDisabled="True"/>
                                            </DockPanel>
                                            <CheckBox Content="播送IP" DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" IsChecked="{Binding WebhookMessages.BroadcastIP}" ToolTip="服务器就绪通知中是否包含服务器IP地址" ToolTipService.ShowOnDisabled="True"/>
                                            <CheckBox Content="播送SteamID" DataContext="{Binding SelectedItem, ElementName=ServerCombo}" IsEnabled="{Binding IsChecked, ElementName=WebhookCheck}" IsChecked="{Binding WebhookMessages.BroadcastSteamID}" ToolTip="服务器就绪通知中是否包含服务器SteamID" ToolTipService.ShowOnDisabled="True"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </GroupBox>
                    </TabItem>

                    <TabItem Header="服务器设置" IsEnabled="False">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="选择要自定义的服务器：" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <ComboBox Name="ServerCombo2" ItemsSource="{Binding Servers}" DisplayMemberPath="vsmServerName" Width="250"/>
                            </DockPanel>
                            <Separator Margin="0,10,0,10"/>
                            <GroupBox Header="RCON">
                                <StackPanel>
                                    <CheckBox Name="RCONCheck" Content="自动消息" DataContext="{Binding SelectedItem, ElementName=ServerCombo2}" IsChecked="{Binding RconServerSettings.Enabled}" ToolTip="启用RCON远程控制台功能，用于发送命令（如重启通知）"/>

                                    <DockPanel Margin="0,5,0,0">
                                        <TextBlock Text="IP地址：" Width="150" VerticalAlignment="Center"/>
                                        <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo2}" IsEnabled="{Binding IsChecked, ElementName=RCONCheck}" Text="{Binding RconServerSettings.IPAddress}" ToolTip="服务器的RCON监听IP（通常为127.0.0.1或服务器IP）"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,5,0,0">
                                        <TextBlock Text="端口：" Width="150" VerticalAlignment="Center"/>
                                        <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo2}" IsEnabled="{Binding IsChecked, ElementName=RCONCheck}" Text="{Binding RconServerSettings.Port}" ToolTip="服务器的RCON端口（默认25575，需与服务器配置一致）"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,5,0,0">
                                        <TextBlock Text="密码：" Width="150" VerticalAlignment="Center"/>
                                        <TextBox DataContext="{Binding SelectedItem, ElementName=ServerCombo2}" IsEnabled="{Binding IsChecked, ElementName=RCONCheck}" Text="{Binding RconServerSettings.Password}" ToolTip="RCON连接密码（需与服务器配置一致）"/>
                                    </DockPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="其余">
                                <StackPanel>
                                    <CheckBox x:Name="AutoStartCheck" Content="自动启动" DataContext="{Binding SelectedItem, ElementName=ServerCombo2}" IsChecked="{Binding AutoStart}" ToolTip="VSM启动时是否自动启动该服务器"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </ScrollViewer>
        <Button Grid.Row="1" DockPanel.Dock="Bottom" Content="保存" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                Width="80" Margin="0,10,0,10" 
                Click="SaveButton_Click"/>
    </Grid>
</Window>
