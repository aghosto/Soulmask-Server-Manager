<Window x:Class="SoulmaskServerManager.BackgroundManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        ui:WindowHelper.UseModernWindowStyle="True"
        mc:Ignorable="d"
        Title="背景图管理" Height="500" Width="700" MinHeight="400" MinWidth="500"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddImageButton" Click="AddImage_Click" Padding="10,5" ToolTip="选择图片添加到背景图文件夹">
                <DockPanel>
                    <ui:SymbolIcon Symbol="Add" Margin="0,0,5,0"/>
                    <TextBlock Text="添加图片" VerticalAlignment="Center"/>
                </DockPanel>
            </Button>
            <Button x:Name="DeleteImageButton" Click="DeleteImage_Click" Padding="10,5" Margin="10,0,0,0" IsEnabled="False" ToolTip="删除选中的背景图">
                <DockPanel>
                    <ui:SymbolIcon Symbol="Delete" Margin="0,0,5,0"/>
                    <TextBlock Text="删除选中" VerticalAlignment="Center"/>
                </DockPanel>
            </Button>
            <Button x:Name="RefreshButton" Click="Refresh_Click" Padding="10,5" Margin="10,0,0,0" ToolTip="刷新背景图列表">
                <DockPanel>
                    <ui:SymbolIcon Symbol="Refresh" Margin="0,0,5,0"/>
                    <TextBlock Text="刷新" VerticalAlignment="Center"/>
                </DockPanel>
            </Button>
        </StackPanel>

        <ListBox x:Name="ImageListBox" Grid.Row="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionChanged="ImageListBox_SelectionChanged"
                 MouseDoubleClick="ImageListBox_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <primitives:UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5" CornerRadius="4">
                        <StackPanel>
                            <Image Source="{Binding ImageSource}" Width="180" Height="120" Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding FileName}" TextAlignment="Center" Margin="0,5,0,0" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="透明度：" VerticalAlignment="Center" FontSize="16"/>
                <Slider x:Name="OpacitySlider" Width="220" Minimum="0.05" Maximum="1" LargeChange="0.1" SmallChange="0.05"
                        ValueChanged="OpacitySlider_ValueChanged" Margin="5,0,5,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="OpacityValueText" Text="30%" VerticalAlignment="Center" FontSize="14" Width="50"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetButton" Click="ResetWallpaper_Click" Padding="15,5" ToolTip="清除当前背景图，恢复默认界面">
                    <TextBlock Text="重置背景" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="ApplyButton" Click="Apply_Click" Padding="15,5" IsEnabled="False" ToolTip="将选中的图片设为主界面背景图">
                    <TextBlock Text="设为封面" VerticalAlignment="Center"/>
                </Button>
                <Button Click="Close_Click" Padding="15,5" Margin="10,0,0,0">
                    <TextBlock Text="关闭" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
