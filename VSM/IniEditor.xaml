<Window x:Class="SoulmaskServerManager.IniEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019" xmlns:local="clr-namespace:SoulmaskServerManager"
        mc:Ignorable="d"
        Title="IniEditor" Height="778" Width="600">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 10 0">
            <!--<Button Content="打开" Click="Open_Click" Margin="5 0 0 0"/>-->
            <Button Content="保存" Click="Save_Click" Margin="5 0 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0 10 0 0">
            <GroupBox Header="服务器设置">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel Margin="5" Grid.Row="0">
                        <StackPanel>
                            <TextBlock FontSize="15">服务器名称:</TextBlock>
                            <TextBox x:Name="TxtServerName" Height="75" TextWrapping="Wrap"/>

                            <DockPanel  Grid.Row="1">
                                <StackPanel>
                                    <DockPanel Margin="0 10 0 0">
                                        <TextBlock Margin="0 8 0 0" FontSize="15">最大玩家数:</TextBlock>
                                        <ui:NumberBox x:Name="TxtMaxPlayers" SpinButtonPlacementMode="Inline"/>

                                        <ComboBox 
                                                x:Name="pvpModSelect" 
                                                VerticalAlignment="Top" 
                                                Width="Auto" 
                                                OverridesDefaultStyle="True">
                                            <ComboBoxItem Content="PVE"/>
                                            <ComboBoxItem Content="PVP"/>
                                        </ComboBox>
                                    </DockPanel>
                                    <DockPanel>

                                        <StackPanel Margin="0 10 0 0">
                                            <TextBlock Margin="0 8 0 0" FontSize="15">写入硬盘间隔(秒)：</TextBlock>
                                            <TextBox x:Name="TxtBackup" Width="150"/>
                                            <TextBlock Margin="0 8 0 0" FontSize="15">写入内存间隔(分)：</TextBlock>
                                            <TextBox x:Name="TxtSaving" Width="150"/>
                                            <TextBlock Margin="0 8 0 0" FontSize="15">存档备份间隔(秒)：</TextBlock>
                                            <TextBox x:Name="BackupInterval" Text="300" Width="150"/>
                                        </StackPanel>

                                        <StackPanel Margin="10 10 0 0">
                                            <TextBlock Margin="0 8 0 0" FontSize="15">进服密码：</TextBlock>
                                            <TextBox x:Name="Psw" Width="150" HorizontalAlignment="Right"/>
                                            <TextBlock Margin="0 8 0 0" FontSize="15">管理密码：</TextBlock>
                                            <TextBox x:Name="AdminPsw" Width="150" HorizontalAlignment="Right"/>
                                            <TextBlock Margin="0 8 25 0" FontSize="15">备份保存份数：</TextBlock>
                                            <TextBox x:Name="BackupAmount" Text="5"/>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                                
                                <StackPanel Margin="0 10 0 0">
                                    <TextBlock Text="参与服务器集群" FontSize="15" Margin="10 8 0 0"/>
                                    <ComboBox 
                                            x:Name="ClusterModeComboBox"
                                            Width="220"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            SelectionChanged="ClusterModeComboBox_SelectionChanged">
                                        <ComboBoxItem Tag="None" Content="无" ToolTip="不参与服务器集群"/>
                                        <ComboBoxItem Tag="MainServer" Content="作为主服务器" ToolTip="作为集群主服务器"/>
                                        <ComboBoxItem Tag="SubServer" Content="作为副服务器" ToolTip="关联到一个主服务器"/>
                                    </ComboBox>
                                    <TextBlock Text="选择主服务器" FontSize="15" Margin="10 8 0 0"/>
                                    <ListBox 
                                            x:Name="MainServerListBox"
                                            Width="220"
                                            Height="120"
                                            HorizontalAlignment="Center"
                                            Margin="0 5 0 0"
                                            Visibility="Collapsed">
                                        <!-- 默认隐藏 -->
                                    </ListBox>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="连接设置">
                <DockPanel Margin="0 10 0 0">
                    <TextBlock FontSize="15" ToolTip="玩家连接服务器的端口，若有多个服务器需区分开" 
                               Margin="0 5 0 0">
                        连接端口：</TextBlock>
                    <ui:NumberBox x:Name="TxtPort" Text="8777" Maximum="65535" SpinButtonPlacementMode="Inline" Width="220"/>

                    <TextBlock FontSize="15" ToolTip="可使用Telnet功能对服务器发送关服等指令，若有多个服务器建议区分开" 
                               Margin="30 5 0 0">
                        监听端口：</TextBlock>
                    <ui:NumberBox x:Name="EchoPort" Text="18888" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="Steam在线辅助系统" Margin="0 10 0 0">
                <StackPanel Margin="0 10 0 0">
                    <TextBlock FontSize="15" ToolTip="给Steam查询你的服务器的端口，若有多个服务器建议区分开">
                        服务器查询端口：</TextBlock>
                    <ui:NumberBox x:Name="QueryPort" Text="27015" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>

</Window>
